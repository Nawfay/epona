# --- GO Transit ---
GO_API_KEY=your_metrolinx_api_key_here
HOME_STATION=MA          # Markham GO stop code (verify with scripts/probe_go.py)
WORK_STATION=UN          # Union Station stop code (verify with scripts/probe_go.py)
LINE=ST                  # Stouffville line code (verify with scripts/probe_go.py)
TIMEZONE=America/Toronto
MIN_DEPARTURE_BUFFER_MINUTES=2

# --- Discord ---
ENABLE_DISCORD=true
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_app_id
DISCORD_GUILD_ID=         # Optional: dev server ID for instant slash command sync

# --- Slack ---
ENABLE_SLACK=true
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-level-token
